# Variables de entorno para desarrollo y producción
# Copia este archivo a .env y personaliza los valores según el entorno

# ─── Servidor ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANTE: cambia JWT_SECRET por un valor aleatorio largo en producción
JWT_SECRET=cambia-esto-por-un-secreto-seguro-en-produccion
JWT_EXPIRY_MINUTES=60

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# ─── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_NAME=jobs-queue
# Desarrollo local (LocalStack). En producción quitar esta línea.
SQS_ENDPOINT=http://localstack:4566

# ─── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=jobs
# Desarrollo local (LocalStack). En producción quitar esta línea.
DYNAMODB_ENDPOINT=http://localstack:4566

# ─── Worker ────────────────────────────────────────────────────────────────────
# Identificador de instancia del worker (útil cuando corren varios en paralelo)
WORKER_INSTANCE_ID=worker-1
# Número de threads concurrentes del worker
WORKER_CONCURRENCY=4

# ─── Usuarios de prueba (solo desarrollo local) ──────────────────────────
USERS_TABLE_NAME=users
ADMIN_USER=superadmin
ADMIN_PASSWORD=admin123
TEST_USER=usuario1
TEST_PASSWORD=test123
