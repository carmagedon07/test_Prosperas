# ============================================================
# Variables de entorno para desarrollo y producción
# ============================================================
# Copia este archivo a .env y personaliza los valores según el entorno
# Para LocalStack (desarrollo): usar valores por defecto sin modificar
# Para AWS (producción): eliminar *_ENDPOINT y usar credenciales IAM reales

# ─── Servidor ──────────────────────────────────────────────────────────────────
# Puerto donde escucha el servidor FastAPI
# Default: 8000 | Requerido: Sí | Ejemplo: 8000, 8080
BACKEND_PORT=8000

# URL del frontend para validación CORS
# Default: http://localhost:3000 | Requerido: Sí
# Producción: https://tu-dominio.cloudfront.net
FRONTEND_URL=http://localhost:3000

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secreto para firmar tokens JWT (HS256)
# Default: (inseguro) | Requerido: Sí | Formato: string largo aleatorio
# IMPORTANTE: en producción usar al menos 32 caracteres aleatorios
# Generar con: openssl rand -base64 32
# En AWS: se obtiene automáticamente de SSM Parameter Store
JWT_SECRET=cambia-esto-por-un-secreto-seguro-en-produccion-minimo-32-caracteres

# Tiempo de expiración del token JWT en minutos
# Default: 60 | Requerido: Sí | Rango recomendado: 15-1440 (1 día)
JWT_EXPIRY_MINUTES=60

# ─── AWS ───────────────────────────────────────────────────────────────────────
# Credenciales AWS para acceso a servicios (DynamoDB, SQS, SSM)
# LocalStack: usar 'test' / 'test' (cualquier valor funciona)
# Producción: dejar vacío si usas IAM roles (ECS Task Role recomendado)
#             o configurar con credentials de un IAM user
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Región AWS donde están desplegados los recursos
# Default: us-east-1 | Requerido: Sí | Ejemplo: us-east-1, us-west-2
AWS_REGION=us-east-1

# ID de cuenta AWS (solo para referencia, no usado en código)
# Útil para construir ARNs manualmente si se necesita
# AWS_ACCOUNT_ID=521434189536

# ─── SQS ───────────────────────────────────────────────────────────────────────
# Nombre de la cola SQS para jobs de procesamiento asíncrono
# LocalStack: jobs-queue | Producción: prospera-jobs-queue
# Se usa para obtener la URL de la cola con get_queue_url()
SQS_QUEUE_NAME=jobs-queue

# URL completa de la cola SQS (opcional, se calcula automáticamente)
# Si se define, tiene prioridad sobre SQS_QUEUE_NAME
# Ejemplo: https://sqs.us-east-1.amazonaws.com/521434189536/prospera-jobs-queue
# SQS_QUEUE_URL=

# Endpoint de SQS (solo para desarrollo local con LocalStack)
# LocalStack: http://localstack:4566 | Producción: ELIMINAR ESTA LÍNEA
# Si está definido, apunta a LocalStack; si está vacío/ausente, usa AWS real
SQS_ENDPOINT=http://localstack:4566

# ─── DynamoDB ──────────────────────────────────────────────────────────────────
# Nombre de la tabla DynamoDB para almacenar jobs
# LocalStack: jobs | Producción: prospera-jobs
DYNAMODB_TABLE_NAME=jobs

# Endpoint de DynamoDB (solo para desarrollo local con LocalStack)
# LocalStack: http://localstack:4566 | Producción: ELIMINAR ESTA LÍNEA
# Si está definido, apunta a LocalStack; si está vacío/ausente, usa AWS real
DYNAMODB_ENDPOINT=http://localstack:4566

# ─── Worker ────────────────────────────────────────────────────────────────────
# Identificador único de la instancia del worker
# Útil para debugging cuando hay múltiples workers ejecutándose
# Default: worker-1 | Formato: worker-N donde N es número
# En ECS, se puede inyectar dinámicamente con task ID
WORKER_INSTANCE_ID=worker-1

# Número de threads concurrentes por instancia de worker
# Cada thread puede procesar un job simultáneamente
# Default: 4 | Rango recomendado: 2-10
# Con 2 workers × 4 threads = 8 jobs en paralelo máximo
WORKER_CONCURRENCY=4

# Tiempo de visibilidad de mensajes SQS en segundos (configurado en código)
# Define cuánto tiempo un mensaje está oculto mientras se procesa
# Valor en código: 180s (3 min) para jobs de 60-90s
# Si los jobs tardan más, aumentar en worker/main.py línea 103

# ─── Usuarios de prueba (solo desarrollo local) ──────────────────────────
# Estas variables solo se usan en seed.py para crear usuarios iniciales

# Nombre de la tabla DynamoDB para usuarios
# LocalStack: users | Producción: prospera-users
USERS_TABLE_NAME=users

# Credenciales del usuario administrador
# Solo creado automáticamente en LocalStack por seed.py
# En producción AWS: crear manualmente con script create_admin.py
ADMIN_USER=superadmin
ADMIN_PASSWORD=admin123

# Credenciales de usuario de prueba estándar
# Solo para desarrollo local, no crear en producción
TEST_USER=usuario1
TEST_PASSWORD=test123

# ─── Logging (opcional) ────────────────────────────────────────────────────────
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO | Desarrollo: DEBUG | Producción: INFO o WARNING
# LOG_LEVEL=INFO

# Formato de logs: json (estructurado) o text (legible)
# Default: text | Producción recomendado: json
# LOG_FORMAT=text
